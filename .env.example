# CLAW System — Environment Variables
# Copy to .env (or set in ~/.claude/settings.json "env" block). Never commit .env.

# ════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════

# --- Supabase (memory, activity log, queue) ---
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Supabase management token (for MCP). Different from anon key.
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# --- Google Gemini (embeddings, session analysis) ---
# Get from: https://aistudio.google.com/app/apikey
# Free tier sufficient for <50 sessions/day
GEMINI_API_KEY=AIza...


# ════════════════════════════════════════════════════════════
# OPTIONAL — Telegram (mobile gateway + heartbeat reports)
# ════════════════════════════════════════════════════════════

# Create a bot via @BotFather on Telegram, get the token.
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID. Get via @userinfobot.
# Used as allow-list for the bot (only you can talk to it).
TELEGRAM_AUTHORIZED_ID=


# ════════════════════════════════════════════════════════════
# OPTIONAL — n8n integration (external workflow automation)
# ════════════════════════════════════════════════════════════

N8N_URL=https://<your-instance>.app.n8n.cloud
N8N_API_KEY=


# ════════════════════════════════════════════════════════════
# OPTIONAL — Webhook secret (for external systems calling CLAW)
# ════════════════════════════════════════════════════════════

# Generate: openssl rand -hex 32
CLAW_WEBHOOK_SECRET=


# ════════════════════════════════════════════════════════════
# TUNING (optional)
# ════════════════════════════════════════════════════════════

# Percent of context window before auto-compact triggers.
# Default ~95. Set to 99 to minimize mid-session compacts.
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=99

# MCP server startup timeout (ms). Increase if you see "MCP timeout" errors.
# Default 30000. Set 60000 if analytics-mcp or similar slow MCPs time out.
MCP_TIMEOUT=60000
