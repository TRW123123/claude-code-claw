# CLAW System — Environment Variables
# Copy to .env and fill in your own values. Never commit .env.

# --- Supabase (memory, activity log, queue) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Google Gemini (embeddings, semantic memory search) ---
GEMINI_API_KEY=

# --- Telegram Bot (optional — mobile control gateway) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_ID=

# --- n8n (optional — workflow automation) ---
N8N_URL=
N8N_API_KEY=

# --- Webhook secret for CLAW event ingestion ---
CLAW_WEBHOOK_SECRET=

# --- Claude Code harness tuning (optional) ---
# Percent of context window after which auto-compact kicks in (default 80)
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=
